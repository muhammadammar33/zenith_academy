generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum RegistrationStatus {
  PENDING
  CONFIRMED
  REJECTED
}

enum EmailStatus {
  PENDING
  SENT
  FAILED
}

model Domain {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  line        String
  about       String   @db.Text
  outcome     String   @db.Text
  imageUrl    String
  imageAlt    String
  themes      String[]
  sortOrder   Int      @default(0)
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  courses Course[]

  @@index([isPublished, sortOrder])
}

model Course {
  id            String   @id @default(cuid())
  title         String
  slug          String   @unique
  description   String   @db.Text
  about         String   @db.Text
  takeaway      String   @db.Text
  audience      String   @db.Text
  duration      String
  mode          String
  status        String
  fee           Int
  seats         String
  imageUrl      String
  imageAlt      String
  prerequisites String[]
  sessions      String[]
  sortOrder     Int      @default(0)
  isPublished   Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  domainId String
  domain   Domain @relation(fields: [domainId], references: [id], onDelete: Restrict)

  registrations Registration[]

  @@index([domainId, isPublished, sortOrder])
}

model Registration {
  id              String             @id @default(cuid())
  fullName        String
  cnic            String
  dateOfBirth     DateTime
  gender          String
  phone           String
  email           String
  educationLevel  String
  institution     String
  degreeProgram   String?
  studyYear       String
  courseTitle     String
  courseFee       Int
  courseMode      String
  paymentMethod   String
  receiptUrl      String
  receiptPublicId String
  status          RegistrationStatus @default(PENDING)
  adminNotes      String?            @db.Text
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  courseId String
  course   Course @relation(fields: [courseId], references: [id], onDelete: Restrict)

  @@index([status, createdAt])
  @@index([email])
  @@index([courseId])
}

model MediaAsset {
  id           String   @id @default(cuid())
  publicId     String   @unique
  secureUrl    String
  resourceType String
  format       String?
  width        Int?
  height       Int?
  bytes        Int?
  altText      String?
  createdAt    DateTime @default(now())

  @@index([createdAt])
}

model SiteSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

model EmailLog {
  id        String      @id @default(cuid())
  recipient String
  subject   String
  status    EmailStatus @default(PENDING)
  error     String?     @db.Text
  createdAt DateTime    @default(now())
  sentAt    DateTime?

  @@index([status, createdAt])
}
