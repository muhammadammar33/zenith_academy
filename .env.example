# PostgreSQL
# Local Postgres usually needs no SSL. Hosted providers: use sslmode=verify-full
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/zenith_academy"

# Single administrator
ADMIN_EMAIL="admin@example.com"
# Generate with: node -e "require('bcryptjs').hash('replace-me', 12).then(console.log)"
ADMIN_PASSWORD_HASH="$2b$12$replace_with_a_bcrypt_hash"
ADMIN_SESSION_SECRET="replace-with-at-least-32-random-characters"

# Public application URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# SMTP
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="smtp-user"
SMTP_PASSWORD="smtp-password"
SMTP_FROM="Zenith Academy <academy@example.com>"
SMTP_ADMIN_TO="admin@example.com"

# Media storage
MEDIA_CLOUD_NAME="your-cloud-name"
MEDIA_API_KEY="your-api-key"
MEDIA_API_SECRET="your-api-secret"
MEDIA_FOLDER="zenith-academy"
